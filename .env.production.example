# ── Helpdesk · .env de PRODUCCIÓN (Plesk) ─────────────────────────────────────
# Copia este archivo a «.env», rellena los DB_* y APP_URL, y entra a
#   https://TU-DOMINIO/install.php
# El instalador genera la APP_KEY, crea las tablas y el usuario admin.

APP_NAME="Helpdesk"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://TU-DOMINIO
APP_TIMEZONE=Europe/Madrid
APP_LOCALE=es
APP_FALLBACK_LOCALE=es

# ── Base de datos (créala en Plesk → Bases de datos) ──────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=CAMBIA_nombre_bd
DB_USERNAME=CAMBIA_usuario
DB_PASSWORD=CAMBIA_contraseña

# ── Infra para un despliegue de PRUEBAS sencillo ──────────────────────────────
# sync: los trabajos se ejecutan al momento (no hace falta un worker de colas).
QUEUE_CONNECTION=sync
SESSION_DRIVER=database
CACHE_STORE=database
# log: sin websocket real; la app de agentes cae a sondeo y el portal ya sondea.
BROADCAST_CONNECTION=log

# ── Correo ────────────────────────────────────────────────────────────────────
# El buzón real (IMAP/SMTP) se configura DENTRO de la app: Agentes → Configuración
# → «Buzón y envío». Aquí solo el respaldo de Laravel (a log si no se toca).
MAIL_MAILER=log
MAIL_FROM_ADDRESS="soporte@TU-DOMINIO"
MAIL_FROM_NAME="${APP_NAME}"
